int main(void)
{
    /* Loop forever */

	/* Step 1: Enabling RCC clock of GPIOA connected to AHB1 bus */

	uint32_t RCC_BASE_ADDR = 0x40023800U;

	uint32_t* GPIOA_CLCK_EN_REG = (uint32_t*)(RCC_BASE_ADDR + 0x30U);

	*GPIOA_CLCK_EN_REG |= (1 << 0);

	/* Step 2: Button is connected to PA0.....Set PA0 as input in Port mode Register   */

	uint32_t GPIOA_BASE_ADDR = 0x40020000U;

	uint32_t* GPIOA_PORT_MOD_REG = (uint32_t*)(GPIOA_BASE_ADDR + 0x00U);

	*GPIOA_PORT_MOD_REG &= ~(1 << 0);   /* Reset bit 0 */
	*GPIOA_PORT_MOD_REG &= ~(1 << 1);   /* Reset bit 1 */

	/* Step 3: Configure Pull down Register */

	/* Pull-up/Pull-down resistor gives input pin a default value when nothing is driving it */

	/* Pull-up resistor: Button not pressed --> 1 */
	/* Pull-up resistor: Button pressed --> 0 */

	/* Pull-down resistor: Button not pressed --> 0 */
	/* Pull-down resistor: Button pressed --> 1 */

	/* We are setting Configuring Pull-down resistor by choice */

	uint32_t* GPIOA_PUPD_REG = (uint32_t*)(GPIOA_BASE_ADDR + 0x0CU);

	*GPIOA_PUPD_REG |= (1 << 1);
	*GPIOA_PUPD_REG &= ~(1 << 0);

	/* Step 4: Set Input data register for PA0 */

	uint32_t* GPIOA_IDR_REG = (uint32_t*)(GPIOA_BASE_ADDR + 0x10U);

	while(1){
		while(*GPIOA_IDR_REG & (1 << 0)){
			printf("Button Pressed");
		}
		printf("Not Pressed");
	}


	for(;;);
}
