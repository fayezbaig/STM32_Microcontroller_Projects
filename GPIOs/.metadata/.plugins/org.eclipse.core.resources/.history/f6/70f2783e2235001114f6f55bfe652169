#include <stdint.h>

#if !defined(__SOFT_FP__) && defined(__ARM_FP)
  #warning "FPU is not initialized, but the project is compiling for an FPU. Please initialize the FPU before use."
#endif

int main(void)
{
    /* Loop forever */

	/* Connect LEDs on PA1 PA2 PA3 and PA4*/

	/* Step 1: Enable the clock of GPIOA on AHB1 bus */

	uint32_t RCC_BASE_ADDR = 0x40023800U;

	uint32_t* GPIOA_PERI_CLCK_REG = (uint32_t*)(RCC_BASE_ADDR + 0x30U);

	*GPIOA_PERI_CLCK_REG |= (1 << 0);

	/* Step 2: Set pin PA1, PA2, PA3 and PA4 as output */

	uint32_t GPIOA_BASE_ADDR = 0x40020000U;

	uint32_t* GPIOA_PORT_MOD_REG = (uint32_t*)(GPIOA_BASE_ADDR +  0x00U);

	*GPIOA_PORT_MOD_REG |= (1 << 2);    /* Configuring Pin PA1 as output */
	*GPIOA_PORT_MOD_REG &= ~(1 << 3);

	*GPIOA_PORT_MOD_REG |= (1 << 4);    /* Configuring Pin PA2 as output */
	*GPIOA_PORT_MOD_REG &= ~(1 << 5);

	*GPIOA_PORT_MOD_REG |= (1 << 6);    /* Configuring Pin PA3 as output */
	*GPIOA_PORT_MOD_REG &= ~(1 << 7);

	/* Step 3: Write to ODR register of these pins */

	uint32_t* GPIOA_ODR_REG = (uint32_t*)(GPIOA_BASE_ADDR +  0x14U);

	while(1){
		for(uint32_t i=1; i<4; i++){

			*GPIOA_ODR_REG |= (1 << i);
			for(uint32_t j = 0; j < 10000; j++);
			*GPIOA_ODR_REG &= ~(1 << i);
			for(uint32_t j = 0; j < 10000; j++);
		}
	}

	for(;;);
}
