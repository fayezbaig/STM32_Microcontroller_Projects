int main(void)
{
    /* Step 1: Enable Clock of GPIOA (AHB1 peripherals)*/

	/* Connect the long leg of pin on PA6 and short leg on GND */

	/* Check the Base Address of RCC register, find the base address of that bus on which GPIOA is connected and enable the clock for that port......Check page 65 then 182 */

	uint32_t  RCC_BASE_ADDR = 0x40023800U;

	uint32_t* AHB1_PER_CLCK_REG = (uint32_t*)(RCC_BASE_ADDR + 0x30U);     /* 0x30 is the offset value for Peripheral Clock Enable Rrgister.....See page 244*/

	*AHB1_PER_CLCK_REG |= (1 << 0);       /* See page 244......Same technique can be use to enable clock of any Peripheral inside any Bus*/

    /* Step 2: Configure the pin (PA6) as Output Mode .........SEE PAGE 284*/

	uint32_t GPIOA_BASE_ADDR = 0x40020000U;   /* Check page 65 */

	uint32_t* GPIO_PORT_MODE_ADDR = (uint32_t*)(GPIOA_BASE_ADDR + 0x00U);

	*GPIO_PORT_MODE_ADDR |= (1 << 12);
	*GPIO_PORT_MODE_ADDR &= ~(1 << 13);


	/* Step 3: Write to Output Data Register */

	uint32_t* GPIO_OUTPUT_REG = (uint32_t*)(GPIOA_BASE_ADDR + 0x14U);  /* 0x14 is the base address of GPIO Port Output Type Register....See page 286 */

	uint32_t N = 2;

	while(1){

	*GPIO_OUTPUT_REG |= (1 << 6);

	for(uint32_t i = 0; i < N; i++);

	*GPIO_OUTPUT_REG &= ~(1 << 6);
	}

	for(;;);
}
