void EXTI2_IRQHandler(void){

	uint32_t GPIOA_BASE_ADDR = 0x40020000U;
	uint32_t EXTI_BASE_ADDR = 0x40013C00U;

	uint32_t* GPIOA_ODR_REG = (uint32_t*)(GPIOA_BASE_ADDR + 0x14U);

	uint32_t* EXTI_PR = (uint32_t*)(EXTI_BASE_ADDR +  0x14U);


	if(*EXTI_PR & (1 << 2))
		    {
		        *GPIOA_ODR_REG ^= (1 << 1);   /* Toggle LED */

		        *EXTI_PR |= (1 << 2);     /* Clear pending */
		    }

}

void EXTI3_IRQHandler(void){

	uint32_t GPIOA_BASE_ADDR = 0x40020000U;
	uint32_t EXTI_BASE_ADDR = 0x40013C00U;

	uint32_t* GPIOA_ODR_REG = (uint32_t*)(GPIOA_BASE_ADDR + 0x14U);

	*GPIOA_ODR_REG &= ~(1 << 6);   /* Resting PA6 to 0*/

	uint32_t* EXTI_PR = (uint32_t*)(EXTI_BASE_ADDR +  0x14U);


	if(*EXTI_PR & (1 << 3))
			   {
			        *GPIOA_ODR_REG ^= (1 << 1);   /* Toggle LED */

			        *EXTI_PR |= (1 << 3);     /* Clear pending */
			    }

}
